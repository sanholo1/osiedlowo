# Frontend Environment Variables
# Skopiuj ten plik jako .env i dostosuj wartości

# ==================================
# KONFIGURACJA API
# ==================================

# URL backendu API
# - http://localhost:3001 (dla lokalnego developmentu)
# - https://api.twoja-domena.com (dla produkcji)
REACT_APP_API_URL=http://localhost:3001

# ==================================
# OPCJONALNE
# ==================================

# Port frontendu (domyślnie 3000)
# PORT=3000

# Czy otwierać przeglądarkę automatycznie
# BROWSER=none
