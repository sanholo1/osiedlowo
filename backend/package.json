{
  "name": "osiedlowo-backend",
  "version": "1.0.0",
  "description": "Backend API for Osiedlowo application",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/simple-server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/simple-server.ts",
    "dev:simple": "ts-node src/simple-server.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/database.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/database.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/database.ts",
    "schema:sync": "typeorm-ts-node-commonjs schema:sync -d src/config/database.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "typeorm": "^0.3.17",
    "mysql2": "^3.6.5",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.1.13",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "typeorm",
    "mysql",
    "cqrs"
  ],
  "author": "Osiedlowo Team",
  "license": "MIT"
}