{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "*"
      ],
      "@config/*": [
        "config/*"
      ],
      "@modules/*": [
        "modules/*"
      ],
      "@dtos": [
        "dtos"
      ],
      "@dtos/*": [
        "dtos/*"
      ],
      "@entities": [
        "entities"
      ],
      "@entities/*": [
        "entities/*"
      ],
      "@exceptions": [
        "exceptions"
      ],
      "@exceptions/*": [
        "exceptions/*"
      ],
      "@services": [
        "services"
      ],
      "@services/*": [
        "services/*"
      ],
      "@repositories": [
        "repositories"
      ],
      "@repositories/*": [
        "repositories/*"
      ],
      "@controllers": [
        "controllers"
      ],
      "@controllers/*": [
        "controllers/*"
      ],
      "@middleware": [
        "middleware"
      ],
      "@middleware/*": [
        "middleware/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ],
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ]
  }
}